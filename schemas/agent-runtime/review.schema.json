{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review",
  "description": "Machine-readable independent reviewer verdict for an @go run.",
  "type": "object",
  "required": [
    "reviewer_role",
    "reviewer_id",
    "executor_id",
    "verdict",
    "reviewed_inputs",
    "findings"
  ],
  "properties": {
    "reviewer_role": {
      "type": "string",
      "not": { "enum": ["executor", "fixer", "coder"] },
      "description": "Role that produced the review. Must be independent of executor/fixer/coder."
    },
    "reviewer_type": {
      "type": "string",
      "enum": ["ai", "human"],
      "description": "Whether the reviewer is an AI reviewer session or a human reviewer."
    },
    "reviewer_id": {
      "type": "string",
      "minLength": 1,
      "description": "Reviewer session or human identifier."
    },
    "executor_id": {
      "type": "string",
      "minLength": 1,
      "description": "Executor/fixer session identifier."
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "blocked", "fail", "escalate"],
      "description": "Reviewer verdict."
    },
    "reviewed_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "diff.patch",
          "test-output.md",
          "safety-report.json",
          "chain-evidence.json"
        ]
      },
      "uniqueItems": true,
      "minItems": 4,
      "description": "Evidence files the reviewer actually inspected."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "status", "title"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "status": { "type": "string", "enum": ["open", "resolved", "false_positive"] },
          "title": { "type": "string" },
          "details": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "Reviewer findings."
    }
  },
  "additionalProperties": false
}
