{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceManifest",
  "description": "Machine-readable manifest of evidence pack contents, generated by build_evidence_pack.py. Canonical schema for ECS-A2 evidence packs.",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "base_commit",
    "head_commit",
    "generated_at",
    "review_yaml_profile",
    "required_files",
    "files_present",
    "verdict_eligibility",
    "evidence_completeness"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^evidence-manifest\\.v\\d+$",
      "description": "Schema version identifier for the evidence manifest."
    },
    "task_id": {
      "type": "string",
      "description": "Task identifier this evidence pack was built for."
    },
    "run_id": {
      "type": "string",
      "description": "Run identifier. Can be empty for non-dispatch builds."
    },
    "base_commit": {
      "type": "string",
      "description": "Base commit hash of the change range covered by this pack."
    },
    "head_commit": {
      "type": "string",
      "description": "Head commit hash of the change range covered by this pack."
    },
    "commit_chain": {
      "type": "array",
      "description": "Ordered list of commits between base_commit and head_commit (inclusive).",
      "items": {
        "type": "object",
        "required": ["hash", "author", "timestamp", "subject"],
        "properties": {
          "hash": {
            "type": "string",
            "description": "Full commit hash."
          },
          "author": {
            "type": "string",
            "description": "Commit author name."
          },
          "timestamp": {
            "type": "string",
            "description": "Commit timestamp."
          },
          "subject": {
            "type": "string",
            "description": "First line of the commit message."
          }
        },
        "additionalProperties": false
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp when the evidence pack was generated."
    },
    "review_yaml_profile": {
      "type": "string",
      "enum": ["ecs-v1"],
      "description": "Review YAML profile used for this evidence pack."
    },
    "required_files": {
      "type": "object",
      "description": "Files required by tier, as defined by the review profile.",
      "required": ["tier_0", "tier_1"],
      "properties": {
        "tier_0": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tier-0 (mandatory) file names."
        },
        "tier_1": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tier-1 (conditional) file names."
        }
      },
      "additionalProperties": false
    },
    "files_present": {
      "type": "array",
      "items": { "type": "string" },
      "description": "All files present in the evidence pack."
    },
    "files_missing": {
      "type": "object",
      "description": "Files that were expected but missing, grouped by tier.",
      "required": ["tier_0", "tier_1"],
      "properties": {
        "tier_0": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Missing tier-0 (mandatory) files."
        },
        "tier_1": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Missing tier-1 (conditional) files."
        }
      },
      "additionalProperties": false
    },
    "test_summary": {
      "type": "object",
      "description": "Summary of test execution results.",
      "required": ["passed", "test_count", "mode", "summary_line", "log_included"],
      "properties": {
        "passed": {
          "type": "boolean",
          "description": "Whether all tests passed."
        },
        "test_count": {
          "type": "integer",
          "description": "Total number of tests executed."
        },
        "mode": {
          "type": "string",
          "enum": ["full_regression", "targeted_tests", "no_test_rationale"],
          "description": "Test execution mode."
        },
        "summary_line": {
          "type": "string",
          "description": "Human-readable one-line test summary."
        },
        "log_included": {
          "type": "boolean",
          "description": "Whether the full test log is included in the pack."
        }
      },
      "additionalProperties": false
    },
    "runtime_evidence": {
      "type": "object",
      "description": "Runtime evidence scenario results from the evidence pack.",
      "required": ["index_present", "scenario_count", "stale_count", "scenarios"],
      "properties": {
        "index_present": {
          "type": "boolean",
          "description": "Whether a runtime-evidence-index.json is included."
        },
        "scenario_count": {
          "type": "integer",
          "description": "Total number of runtime scenarios."
        },
        "stale_count": {
          "type": "integer",
          "description": "Number of scenarios whose code_version does not match head_commit."
        },
        "scenarios": {
          "type": "array",
          "description": "Individual runtime evidence scenario summaries.",
          "items": {
            "type": ["string", "object"]
          }
        }
      },
      "additionalProperties": false
    },
    "negative_path_evidence": {
      "type": "object",
      "description": "Negative-path (failure / edge-case) scenario evidence.",
      "required": ["present", "scenario_count", "scenarios"],
      "properties": {
        "present": {
          "type": "boolean",
          "description": "Whether negative-path evidence is included in the pack."
        },
        "scenario_count": {
          "type": "integer",
          "description": "Number of negative-path scenarios."
        },
        "scenarios": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names or identifiers of negative-path scenarios."
        }
      },
      "additionalProperties": false
    },
    "git_status": {
      "type": "object",
      "description": "Working-tree status snapshot at pack generation time.",
      "required": ["modified_tracked", "untracked_total", "neg_009", "secret_scan", "session_artifacts"],
      "properties": {
        "modified_tracked": {
          "type": "integer",
          "description": "Number of modified tracked files."
        },
        "untracked_total": {
          "type": "integer",
          "description": "Total number of untracked files."
        },
        "neg_009": {
          "type": "integer",
          "description": "Count of files matching NEG-009 patterns (uncommitted governance changes)."
        },
        "secret_scan": {
          "type": "integer",
          "description": "Count of files flagged by secret scanning."
        },
        "session_artifacts": {
          "type": "integer",
          "description": "Count of session-specific artifacts (IDE, OS, editor temps)."
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "description": "Safety and integrity checks summary.",
      "required": ["secret_scan_clean", "ai_guard_clean", "hook_integrity"],
      "properties": {
        "secret_scan_clean": {
          "type": "boolean",
          "description": "Whether secret scanning found no issues."
        },
        "ai_guard_clean": {
          "type": "boolean",
          "description": "Whether AI guard checks passed."
        },
        "hook_integrity": {
          "type": "string",
          "description": "Result of git hook integrity verification (e.g. 'ok', 'degraded', 'missing')."
        }
      },
      "additionalProperties": false
    },
    "verdict_eligibility": {
      "type": "object",
      "description": "Automated eligibility determination for reviewer verdict.",
      "required": ["status", "reasons", "blocking_signals", "limitation_signals"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["eligible_clean", "eligible_with_limitations", "needs_more_evidence", "not_eligible"],
          "description": "Eligibility status for verdict."
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Human-readable reasons supporting the eligibility status."
        },
        "blocking_signals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Signals that block eligibility."
        },
        "limitation_signals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Signals that limit but do not block eligibility."
        }
      },
      "additionalProperties": false
    },
    "evidence_completeness": {
      "type": "object",
      "description": "Tiered evidence completeness breakdown.",
      "required": [
        "tier_0_required",
        "tier_0_present",
        "tier_0_missing",
        "tier_1_conditional",
        "tier_1_present",
        "tier_1_missing",
        "tier_2_optional"
      ],
      "properties": {
        "tier_0_required": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All tier-0 (mandatory) evidence items."
        },
        "tier_0_present": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tier-0 items that are present in the pack."
        },
        "tier_0_missing": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tier-0 items that are missing from the pack."
        },
        "tier_1_conditional": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All tier-1 (conditional) evidence items."
        },
        "tier_1_present": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tier-1 items that are present in the pack."
        },
        "tier_1_missing": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tier-1 items that are missing from the pack."
        },
        "tier_2_optional": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tier-2 (optional) evidence items present in the pack."
        }
      },
      "additionalProperties": false
    },
    "consistency_check": {
      "type": "object",
      "description": "Cross-file consistency verification result.",
      "required": ["all_files_agree", "computed", "method"],
      "properties": {
        "all_files_agree": {
          "type": "boolean",
          "description": "Whether all evidence files are internally consistent."
        },
        "computed": {
          "type": "boolean",
          "description": "Whether the consistency check was actually computed (vs. skipped)."
        },
        "method": {
          "type": "string",
          "description": "Method used for consistency verification."
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known limitations or caveats of this evidence pack."
    },
    "pack_info": {
      "type": "object",
      "description": "Metadata about the evidence pack archive itself.",
      "required": ["file_count", "zip_size_bytes"],
      "properties": {
        "file_count": {
          "type": "integer",
          "description": "Total number of files in the pack."
        },
        "zip_size_bytes": {
          "type": "integer",
          "description": "Size of the zip archive in bytes."
        },
        "zip_sha256": {
          "type": "string",
          "description": "SHA-256 hash of the zip archive. Note: may differ from final ZIP if manifest was patched post-build."
        },
        "content_sha256": {
          "type": "string",
          "description": "SHA-256 hash of all pack files except evidence-manifest.json. Deterministic and self-verifiable."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": "evidence-manifest.v1",
      "task_id": "TASK-042",
      "run_id": "run-20260612-001",
      "base_commit": "abc1234def5678",
      "head_commit": "fed8765cba4321",
      "commit_chain": [
        {
          "hash": "fed8765cba4321",
          "author": "dev@example.com",
          "timestamp": "2026-06-12T09:30:00Z",
          "subject": "feat: add evidence manifest generation"
        }
      ],
      "generated_at": "2026-06-12T10:00:00Z",
      "review_yaml_profile": "ecs-v1",
      "required_files": {
        "tier_0": ["review.md", "review.yaml", "diff.patch"],
        "tier_1": ["test-log.txt", "runtime-evidence-index.json"]
      },
      "files_present": ["review.md", "review.yaml", "diff.patch", "test-log.txt"],
      "files_missing": {
        "tier_0": [],
        "tier_1": ["runtime-evidence-index.json"]
      },
      "test_summary": {
        "passed": true,
        "test_count": 47,
        "mode": "full_regression",
        "summary_line": "47 passed, 0 failed, 0 skipped",
        "log_included": true
      },
      "runtime_evidence": {
        "index_present": false,
        "scenario_count": 0,
        "stale_count": 0,
        "scenarios": []
      },
      "negative_path_evidence": {
        "present": false,
        "scenario_count": 0,
        "scenarios": []
      },
      "git_status": {
        "modified_tracked": 3,
        "untracked_total": 1,
        "neg_009": 0,
        "secret_scan": 0,
        "session_artifacts": 2
      },
      "safety": {
        "secret_scan_clean": true,
        "ai_guard_clean": true,
        "hook_integrity": "ok"
      },
      "verdict_eligibility": {
        "status": "eligible_with_limitations",
        "reasons": ["All tier-0 files present", "Tests passed"],
        "blocking_signals": [],
        "limitation_signals": ["runtime-evidence-index.json missing"]
      },
      "evidence_completeness": {
        "tier_0_required": ["review.md", "review.yaml", "diff.patch"],
        "tier_0_present": ["review.md", "review.yaml", "diff.patch"],
        "tier_0_missing": [],
        "tier_1_conditional": ["test-log.txt", "runtime-evidence-index.json"],
        "tier_1_present": ["test-log.txt"],
        "tier_1_missing": ["runtime-evidence-index.json"],
        "tier_2_optional": []
      },
      "consistency_check": {
        "all_files_agree": true,
        "computed": true,
        "method": "sha256-cross-verify"
      },
      "limitations": ["Runtime evidence index not generated due to missing --extra-dir"],
      "pack_info": {
        "file_count": 4,
        "zip_size_bytes": 15234,
        "zip_sha256": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"
      }
    }
  ]
}
