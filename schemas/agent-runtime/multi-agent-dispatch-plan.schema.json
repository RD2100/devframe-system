{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-acceptance/schemas/agent-runtime/multi-agent-dispatch-plan.schema.json",
  "title": "MultiAgentDispatchPlan",
  "description": "Read-only first-wave worker assignment packet for a human-gated multi-agent pilot.",
  "type": "object",
  "required": [
    "plan_id",
    "generated_at",
    "status",
    "executed_external_runtime",
    "source_preflight",
    "conflict_summary",
    "assignments"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["READY", "HUMAN_REQUIRED", "BLOCKED"]
    },
    "executed_external_runtime": {
      "const": false,
      "description": "Dispatch planning is read-only and must not execute external runtimes."
    },
    "source_preflight": {
      "type": "object",
      "required": [
        "path",
        "sha256",
        "generated_at",
        "overall",
        "human_gate_required",
        "executed_external_runtime",
        "detail"
      ],
      "properties": {
        "path": {
          "type": ["string", "null"]
        },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "generated_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "overall": {
          "type": "string",
          "enum": ["PASS", "HUMAN_REQUIRED", "BLOCKED"]
        },
        "human_gate_required": {
          "type": "boolean"
        },
        "executed_external_runtime": {
          "const": false
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "conflict_summary": {
      "type": "object",
      "required": [
        "has_write_conflicts",
        "has_errors",
        "errors",
        "parallel_group_count",
        "compared_write_pairs"
      ],
      "properties": {
        "has_write_conflicts": {
          "type": "boolean"
        },
        "has_errors": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parallel_group_count": {
          "type": "integer",
          "minimum": 0
        },
        "compared_write_pairs": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "maxItems": 2
          }
        }
      },
      "additionalProperties": false
    },
    "assignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "worker_role",
          "parallel_group_id",
          "parallel_safe",
          "project_module",
          "target",
          "why_big_module",
          "allowed_modify_range",
          "forbidden_modify_range",
          "depends_on_interface_contracts",
          "provides_interface_contracts",
          "main_flow_to_connect",
          "real_functionality_required",
          "tests_or_probes_required",
          "required_verification_commands",
          "quality_standard",
          "completion_standard",
          "blocking_conditions",
          "governance_record_requirements",
          "task_spec"
        ],
        "properties": {
          "worker_role": {
            "type": "string",
            "minLength": 1
          },
          "parallel_group_id": {
            "type": "string",
            "minLength": 1
          },
          "parallel_safe": {
            "type": "boolean"
          },
          "project_module": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "why_big_module": {
            "type": "string",
            "minLength": 1
          },
          "allowed_modify_range": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "forbidden_modify_range": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "depends_on_interface_contracts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "provides_interface_contracts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "main_flow_to_connect": {
            "type": "string",
            "minLength": 1
          },
          "real_functionality_required": {
            "type": "string",
            "minLength": 1
          },
          "tests_or_probes_required": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "required_verification_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "quality_standard": {
            "type": "string",
            "minLength": 1
          },
          "completion_standard": {
            "type": "string",
            "minLength": 1
          },
          "blocking_conditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "governance_record_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "task_spec": {
            "$ref": "#/$defs/task_spec"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_spec": {
      "type": "object",
      "required": [
        "task_id",
        "title",
        "priority",
        "status",
        "description"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "status": {
          "type": "string",
          "enum": ["draft", "ready", "in_progress", "completed", "closed", "deferred", "rejected", "accepted_with_limitation", "pending_human_decision"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "$ref": "#/$defs/string_array"
        },
        "assumptions": {
          "$ref": "#/$defs/string_array"
        },
        "risk_notes": {
          "type": "string"
        },
        "estimated_tools": {
          "$ref": "#/$defs/string_array"
        },
        "gate_0": {
          "type": "object",
          "required": [
            "triggered",
            "inventory_evidence",
            "sufficiency_decision"
          ],
          "properties": {
            "triggered": {
              "type": "boolean"
            },
            "trigger_reason": {
              "type": "string"
            },
            "inventory_evidence": {
              "type": "object",
              "required": [
                "queried_sources",
                "matched_capabilities"
              ],
              "properties": {
                "queried_sources": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "matched_capabilities": {
                  "$ref": "#/$defs/string_array"
                },
                "compared_against_request": {
                  "$ref": "#/$defs/string_array"
                }
              },
              "additionalProperties": false
            },
            "rules_checked": {
              "$ref": "#/$defs/string_array"
            },
            "lessons_checked": {
              "$ref": "#/$defs/string_array"
            },
            "sufficiency_decision": {
              "type": "string",
              "enum": [
                "existing_sufficient",
                "existing_partial",
                "new_delta_required",
                "escalate_uncertain"
              ]
            },
            "decision": {
              "type": "string",
              "enum": ["reuse", "build_delta", "escalate"]
            },
            "delta_justification": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "conflict_registry": {
          "type": "object",
          "required": [
            "read_set",
            "write_set"
          ],
          "properties": {
            "read_set": {
              "$ref": "#/$defs/string_array"
            },
            "write_set": {
              "$ref": "#/$defs/string_array"
            },
            "protected_files_touched": {
              "type": "boolean"
            },
            "conflict_level": {
              "type": "string",
              "enum": ["none", "low", "high"]
            }
          },
          "additionalProperties": false
        },
        "security_report": {
          "type": "object",
          "required": [
            "scan_status",
            "new_external_api",
            "env_example_placeholders_only",
            "real_key_patterns_found",
            "staged_diff_secret_scan_run",
            "key_rotation_needed"
          ],
          "properties": {
            "scan_status": {
              "type": "string",
              "enum": ["not_run", "passed", "failed"]
            },
            "new_external_api": {
              "type": "boolean"
            },
            "new_env_variable": {
              "type": "boolean"
            },
            "env_example_placeholders_only": {
              "type": ["boolean", "null"]
            },
            "real_key_patterns_found": {
              "type": ["boolean", "null"]
            },
            "staged_diff_secret_scan_run": {
              "type": "boolean"
            },
            "full_repo_secret_scan_run": {
              "type": "boolean"
            },
            "packaging_artifact_scanned": {
              "type": "boolean"
            },
            "key_rotation_needed": {
              "type": ["boolean", "null"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "READY"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "source_preflight": {
            "properties": {
              "overall": {
                "const": "PASS"
              },
              "human_gate_required": {
                "const": false
              }
            }
          },
          "conflict_summary": {
            "properties": {
              "has_errors": {
                "const": false
              },
              "has_write_conflicts": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "HUMAN_REQUIRED"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "source_preflight": {
            "properties": {
              "human_gate_required": {
                "const": true
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
