{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScriptSafetyRecord",
  "description": "R7 safety record for agent-acceptance native scripts. All scripts require safety assessment. No script may run without human gate. execution_status default = not_run.",
  "type": "object",
  "required": [
    "record_id", "phase", "script_name", "script_path", "script_type",
    "execution_status", "allowed_to_run", "mutation_risk", "network_risk",
    "secret_risk", "expected_side_effects", "forbidden_actions",
    "human_gate_required", "verification_gaps", "next_phase_blocked"
  ],
  "properties": {
    "record_id": { "type": "string" },
    "phase": { "type": "string", "enum": ["R7"] },
    "script_name": { "type": "string" },
    "script_path": { "type": "string" },
    "script_type": { "type": "string", "enum": ["runner", "test", "batch", "report", "queue", "smoke"] },
    "execution_status": { "type": "string", "enum": ["not_run", "human_required", "forbidden"] },
    "allowed_to_run": { "type": "boolean", "const": false },
    "mutation_risk": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
    "network_risk": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
    "secret_risk": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
    "allowed_actions": { "type": "array", "items": { "type": "string" } },
    "forbidden_actions": { "type": "array", "items": { "type": "string" } },
    "expected_side_effects": { "type": "array", "items": { "type": "string" } },
    "evidence_requirements": { "type": "array", "items": { "type": "string" } },
    "human_gate_required": { "type": "boolean" },
    "local_verification_status": { "type": "string", "enum": ["verified", "needs_local_verification", "unverified"] },
    "verification_gaps": { "type": "array", "items": { "type": "string" } },
    "next_phase_blocked": { "type": "boolean" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false,
  "examples": [{
    "record_id": "ssr-run-smoke-001",
    "phase": "R7",
    "script_name": "Run-Smoke.ps1",
    "script_path": "D:\\agent-acceptance\\scripts\\Run-Smoke.ps1",
    "script_type": "smoke",
    "execution_status": "not_run",
    "allowed_to_run": false,
    "mutation_risk": "medium",
    "network_risk": "none",
    "secret_risk": "none",
    "allowed_actions": ["read_script_source", "classify_risk"],
    "forbidden_actions": ["execute", "modify", "schedule", "auto_trigger"],
    "expected_side_effects": ["runs 7 basic health checks", "outputs results to stdout"],
    "evidence_requirements": ["pre_git_status", "post_git_status", "exit_code", "output_log"],
    "human_gate_required": true,
    "local_verification_status": "needs_local_verification",
    "verification_gaps": ["script not executed in this runtime", "dry-run behavior not verified"],
    "next_phase_blocked": true,
    "notes": "Smoke validation script. 7 basic checks. Dry-run by default."
  }]
}
