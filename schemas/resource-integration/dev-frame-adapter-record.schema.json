{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevFrameAdapterRecord",
  "description": "R3 record of a dev-frame orchestration adapter. dev-frame is an orchestration adapter candidate, NOT an active executor. R3 = design only. No execution, no dry-run, no smoke_test.py.",
  "type": "object",
  "required": [
    "record_id", "phase", "resource_id", "adapter_name", "adapter_type",
    "source_root", "source_status", "orchestration_components",
    "execution_entrypoints", "historical_artifacts", "adapter_status",
    "execution_policy", "dry_run_policy", "smoke_validation_policy",
    "allowed_actions", "forbidden_actions", "contract_mapping",
    "runspec_mapping", "evidence_requirements", "human_gate_required",
    "local_verification_status", "verification_gaps", "next_phase_blocked"
  ],
  "properties": {
    "record_id": { "type": "string" },
    "phase": { "type": "string", "enum": ["R3"] },
    "resource_id": { "type": "string" },
    "adapter_name": { "type": "string" },
    "adapter_type": { "type": "string", "enum": ["orchestration_frame", "workflow_hub", "e2e_harness", "smoke_validation_candidate"] },
    "source_root": { "type": "string" },
    "source_status": { "type": "string", "enum": ["exists", "not_found", "not_a_git_repo", "partial"] },
    "orchestration_components": { "type": "array", "items": { "type": "string" } },
    "execution_entrypoints": { "type": "array", "items": { "type": "string" } },
    "historical_artifacts": { "type": "array", "items": { "type": "string" } },
    "adapter_status": { "type": "string", "enum": ["design_only", "adapter_draft", "deferred", "rejected"] },
    "execution_policy": { "type": "string", "enum": ["forbidden"] },
    "dry_run_policy": { "type": "string", "enum": ["design_only", "human_required_future", "forbidden"] },
    "smoke_validation_policy": { "type": "string", "enum": ["historical_only", "script_safety_required", "human_required_future"] },
    "allowed_actions": { "type": "array", "items": { "type": "string" } },
    "forbidden_actions": { "type": "array", "items": { "type": "string" } },
    "contract_mapping": { "type": "array", "items": { "type": "string" } },
    "runspec_mapping": { "type": "string" },
    "evidence_requirements": { "type": "array", "items": { "type": "string" } },
    "human_gate_required": { "type": "boolean" },
    "local_verification_status": { "type": "string", "enum": ["verified", "needs_local_verification", "unverified", "stale", "blocked"] },
    "verification_gaps": { "type": "array", "items": { "type": "string" } },
    "next_phase_blocked": { "type": "boolean" }
  },
  "additionalProperties": false,
  "examples": [{
    "record_id": "dev-frame-adapter-001",
    "phase": "R3",
    "resource_id": "res-devframe-002",
    "adapter_name": "dev-frame Orchestration Adapter",
    "adapter_type": "orchestration_frame",
    "source_root": "D:\\dev-frame",
    "source_status": "exists",
    "orchestration_components": ["ai-workflow-hub", "ai-workflow-hub-e2e", "agent-acceptance", "codegraph"],
    "execution_entrypoints": ["smoke_test.py", "ai-workflow-hub/src/", "ai-workflow-hub-e2e/tests/"],
    "historical_artifacts": ["smoke_report.txt (2026-05-27, 3/3 PASS)"],
    "adapter_status": "design_only",
    "execution_policy": "forbidden",
    "dry_run_policy": "design_only",
    "smoke_validation_policy": "historical_only",
    "allowed_actions": ["read_directory", "read_docs", "read_smoke_report_txt", "git_status"],
    "forbidden_actions": [
      "execute smoke_test.py",
      "execute ai-workflow-hub code",
      "execute ai-workflow-hub-e2e tests",
      "modify D:\\dev-frame",
      "install packages in dev-frame",
      "treat smoke_report as current pass",
      "produce GateResult",
      "expand RunSpec scope",
      "modify .aiworkflow",
      "modify aihub-worktrees",
      "use dev-frame/agent-acceptance as canonical root",
      "run e2e tests",
      "trigger WorkQueue",
      "modify agent-acceptance from dev-frame",
      "auto-advance adapter status"
    ],
    "contract_mapping": ["Appendix A1", "RunSpec (Contract 2)", "EvidenceIndex (Contract 3)"],
    "runspec_mapping": "candidate only; not an active executor",
    "evidence_requirements": ["smoke_report.txt existence", "directory listing"],
    "human_gate_required": true,
    "local_verification_status": "verified",
    "verification_gaps": ["not a git repo (loose collection)", "smoke_test.py not executed in this runtime", "ai-workflow-hub not executed in this runtime"],
    "next_phase_blocked": true
  }]
}
