{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-acceptance/schemas/gpt_review_result.schema.json",
  "title": "GPT Review Result",
  "description": "Canonical schema for GPT review replies. Base fields mandatory for all task types; task_type_specific varies by task_type.",
  "type": "object",
  "required": [
    "REVIEW_RUN_ID",
    "template_version",
    "task_type",
    "review_stage",
    "overall_judgment",
    "reviewer_type",
    "evidence_inspected",
    "blocking_reasons",
    "missing_evidence",
    "scope_violation",
    "fake_green_risk",
    "safety_boundaries_respected",
    "required_next_action",
    "allow_proceed",
    "rationale",
    "created_at",
    "task_type_specific"
  ],
  "properties": {
    "REVIEW_RUN_ID": {
      "type": "string",
      "minLength": 1,
      "description": "Unique review run identifier."
    },
    "template_version": {
      "type": "string",
      "const": "gpt-review-template-v1",
      "description": "Template version this reply conforms to."
    },
    "task_type": {
      "type": "string",
      "enum": [
        "authorization",
        "execution_closure",
        "design_review",
        "paper_contract_design",
        "paper_revision_review",
        "citation_verification",
        "context_handoff",
        "cdp_pilot",
        "archive_governance"
      ],
      "description": "Task type determines which task_type_specific object is valid."
    },
    "review_stage": {
      "type": "string",
      "enum": ["authorization", "execution", "closure", "audit", "handoff"],
      "description": "Stage of the review workflow."
    },
    "overall_judgment": {
      "type": "string",
      "enum": ["accepted", "blocked", "human_required", "review_unverified"],
      "description": "Canonical lowercase snake_case. Accept 'Overall Judgment' as legacy alias during migration."
    },
    "reviewer_type": {
      "type": "string",
      "enum": ["gpt", "human", "agent"]
    },
    "contract_id": {
      "type": ["string", "null"],
      "description": "Contract ID if this review references a specific contract."
    },
    "contract_version": {
      "type": ["string", "null"],
      "description": "Contract version if applicable."
    },
    "evidence_pack": {
      "type": ["object", "null"],
      "description": "Evidence pack metadata. null when review is not pack-based.",
      "properties": {
        "path": { "type": ["string", "null"] },
        "sha256": { "type": ["string", "null"] },
        "manifest_valid": { "type": "boolean" }
      }
    },
    "evidence_inspected": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "inspected"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": ["string", "null"] },
          "inspected": { "type": "boolean" },
          "role": { "type": "string" }
        }
      },
      "description": "Every evidence file GPT actually read. path + inspected required; sha256 optional."
    },
    "blocking_reasons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "MUST be an array. Empty [] means no blocking reasons. NEVER use string 'none'."
    },
    "missing_evidence": {
      "type": "array",
      "items": { "type": "string" },
      "description": "MUST be an array. Empty [] means no missing evidence. NEVER use string 'none'."
    },
    "scope_violation": {
      "type": "boolean",
      "description": "Did the execution exceed authorized scope?"
    },
    "fake_green_risk": {
      "type": "boolean",
      "description": "Is there risk that claimed PASS actually failed?"
    },
    "safety_boundaries_respected": {
      "type": "boolean",
      "description": "Were guard_removal, evidence_cleanup, live CDP, and real user data boundaries respected?"
    },
    "required_next_action": {
      "type": "string",
      "description": "Concrete next step. Use 'none' only if truly no action needed."
    },
    "allow_proceed": {
      "type": "boolean",
      "description": "May the next stage proceed? Constrained by overall_judgment."
    },
    "review_unverified_reason": {
      "type": ["string", "null"],
      "description": "REQUIRED when overall_judgment is review_unverified."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of review."
    },
    "next_task_authorization": {
      "type": "object",
      "description": "REQUIRED when overall_judgment=accepted. Next task to execute.",
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "authorized": { "type": "string", "enum": ["已授权","未授权"] },
        "execute_immediately": { "type": "string", "enum": ["是","否"] },
        "ask_before_starting": { "type": "string", "enum": ["是","否"] }
      }
    },
    "required_fixes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "REQUIRED when overall_judgment=blocked."
    },
    "resubmission_requirements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "REQUIRED when overall_judgment=blocked."
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "description": "Explanation of the judgment."
    },
    "task_type_specific": {
      "type": "object",
      "description": "Task-specific fields. MUST contain exactly one key matching the task_type field value. JSON Schema limitation: cross-field key equality cannot be enforced at schema level; validated by application code.",
      "patternProperties": {
        "^(authorization|execution_closure|design_review|paper_contract_design|paper_revision_review|citation_verification|context_handoff|cdp_pilot|archive_governance)$": {
          "type": "object"
        }
      },
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "overall_judgment": { "const": "accepted" } }
      },
      "then": {
        "properties": { "allow_proceed": { "const": true } }
      }
    },
    {
      "if": {
        "properties": { "overall_judgment": { "const": "blocked" } }
      },
      "then": {
        "properties": { "allow_proceed": { "const": false } }
      }
    },
    {
      "if": {
        "properties": { "overall_judgment": { "enum": ["human_required", "review_unverified"] } }
      },
      "then": {
        "properties": { "allow_proceed": { "const": false } }
      }
    },
    {
      "if": {
        "properties": { "overall_judgment": { "const": "review_unverified" } }
      },
      "then": {
        "required": ["review_unverified_reason"],
        "properties": {
          "review_unverified_reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "overall_judgment": { "const": "accepted" } }
      },
      "then": {
        "required": ["next_task_authorization"],
        "properties": {
          "next_task_authorization": {
            "type": "object",
            "required": ["task_id", "authorized", "execute_immediately"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "overall_judgment": { "const": "blocked" } }
      },
      "then": {
        "required": ["required_fixes", "resubmission_requirements"],
        "properties": {
          "required_fixes": { "type": "array", "minItems": 1 },
          "resubmission_requirements": { "type": "array", "minItems": 1 }
        }
      }
    }
  ]
}
